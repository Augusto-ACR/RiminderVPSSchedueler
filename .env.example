# Scheduler de Rimainder — variables de entorno
# Copiá este archivo a .env y completá los valores. NUNCA commitees .env.

# ── Servidor ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de datos (la MISMA Postgres del agente Python) ───
# Local (docker-compose de este repo): postgresql://rimainder:rimainder@localhost:5432/agent_db
# VPS: postgresql://USER:PASS@agent-postgres:5432/agent_db
DATABASE_URL=postgresql://rimainder:rimainder@localhost:5432/agent_db

# ── Comportamiento del scheduler ──────────────────────────
# Zona horaria del usuario (igual que el agente). Solo se usa para el TEXTO del aviso.
TIMEZONE=America/Argentina/Buenos_Aires
# Ventana de gracia: avisos atrasados más de estos minutos NO se envían (anti-spam).
SCHEDULER_GRACIA_MIN=60
# Recuperación de "stuck": filas en 'enviando' más viejas que esto vuelven a 'pendiente'.
STUCK_TIMEOUT_MIN=5

# ── Canal de envío ────────────────────────────────────────
# 'openwa' = envía de verdad por WhatsApp. 'mock' = solo loguea (probar sin OpenWA).
SENDER_DRIVER=openwa

# ── OpenWA (requeridas si SENDER_DRIVER=openwa) ───────────
OPENWA_URL=http://openwa-api:2785
OPENWA_API_KEY=
OPENWA_SESSION_ID=
